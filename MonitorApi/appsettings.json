  "DataQualityRules": [
    {
      "RuleName": "orphaned_assessments",
      "Description": "Assessment records ที่ไม่มี user",
      "Database": "DEV",
      "ConnectionStringKey": "DevMssql",
      "Severity": "warning",
      "SqlQuery": "SELECT COUNT(*) AS ViolationCount FROM Assessments WHERE CreatedByUserId IS NULL"
    },
    {
      "RuleName": "data_not_flowing_today",
      "Description": "ไม่มี Submission ใหม่วันนี้ (หลัง 10:00)",
      "Database": "DEV",
      "ConnectionStringKey": "DevMssql",
      "Severity": "warning",
      "SqlQuery": "SELECT CASE WHEN COUNT(*) = 0 AND DATEPART(HOUR, GETDATE()) >= 10 THEN 1 ELSE 0 END AS ViolationCount FROM Submissions WHERE CAST(CreatedAt AS DATE) = CAST(GETDATE() AS DATE)"
    }
  ]
