# ============================================================
# OES Monitor Service — Environment Variables Template
# Copy to .env (DEV) or .env.uat (UAT) and fill in values
# ============================================================

# ── Target Environment ──────────────────────────────────────
MONITOR_ENV=DEV

# ── DEV Service Host (IP ของ server ที่รัน DEV services) ──
HOST_DEV=43.229.77.19

# ── UAT Service Host ────────────────────────────────────────
HOST_UAT=43.229.134.32

# ── MSSQL DEV ───────────────────────────────────────────────
MSSQL_HOST_DEV=43.229.77.19
MSSQL_PORT_DEV=1433
MSSQL_USER_DEV=sa
MSSQL_PASSWORD_DEV=YourDevPassword

# ── MSSQL UAT ───────────────────────────────────────────────
MSSQL_HOST_UAT=43.229.134.32
MSSQL_PORT_UAT=1433
MSSQL_USER_UAT=sa
MSSQL_PASSWORD_UAT=YourUatPassword

# ── Grafana ─────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

# ── MonitorApi ──────────────────────────────────────────────
MONITOR_API_PORT=5000

# ── Jenkins (สำหรับ deployment annotations) ─────────────────
GRAFANA_API_KEY=your-grafana-api-key-here
