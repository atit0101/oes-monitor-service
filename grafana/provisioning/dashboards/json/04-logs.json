{
  "uid": "oes-logs",
  "title": "OES Logs",
  "tags": ["oes", "logs"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values(container)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2,
        "label": "Service"
      },
      {
        "name": "level",
        "type": "custom",
        "query": "error,warn,info,debug",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "label": "Log Level"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Error Count (1h)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({container=~\"$service\"} |= \"error\" [1h]))",
          "legendFormat": "Errors"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Warning Count (1h)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(count_over_time({container=~\"$service\"} |= \"warn\" [1h]))",
          "legendFormat": "Warnings"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Log Rate by Level",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "legend": { "displayMode": "table", "placement": "right" }
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "sum(rate({container=~\"$service\"} |= \"error\" [2m]))",
          "legendFormat": "error"
        },
        {
          "expr": "sum(rate({container=~\"$service\"} |= \"warn\" [2m]))",
          "legendFormat": "warn"
        },
        {
          "expr": "sum(rate({container=~\"$service\"} [2m]))",
          "legendFormat": "all"
        }
      ]
    },
    {
      "id": 10,
      "type": "logs",
      "title": "Live Logs",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 11 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{container=~\"$service\"}",
          "legendFormat": ""
        }
      ]
    }
  ]
}
