{
  "uid": "oes-database",
  "title": "OES Database (MSSQL)",
  "tags": ["oes", "database"],
  "timezone": "browser",
  "refresh": "1m",
  "time": { "from": "now-3h", "to": "now" },
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "env",
        "type": "custom",
        "query": "DEV,UAT",
        "current": { "text": "DEV", "value": "DEV" },
        "label": "Environment"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Connection Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active Connections",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "mssql_connections{state=\"connected\"}",
          "legendFormat": "Connected"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Blocked Processes",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "mssql_blocked_processes",
          "legendFormat": "Blocked"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Deadlocks / sec",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "rate(mssql_deadlocks_total[5m])",
          "legendFormat": "Deadlocks/s"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Buffer Cache Hit Ratio",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "mssql_buffer_cache_hit_ratio",
          "legendFormat": "Cache Hit %"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Performance",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Connections Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "targets": [
        {
          "expr": "mssql_connections",
          "legendFormat": "{{state}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Page Read/Write per second",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "iops" }
      },
      "targets": [
        {
          "expr": "rate(mssql_page_reads_total[2m])",
          "legendFormat": "Page Reads/s"
        },
        {
          "expr": "rate(mssql_page_writes_total[2m])",
          "legendFormat": "Page Writes/s"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Transactions & Locks",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Transactions per second",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "targets": [
        {
          "expr": "rate(mssql_transactions_total[2m])",
          "legendFormat": "Transactions/s"
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Lock Waits & Deadlocks",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "targets": [
        {
          "expr": "rate(mssql_lock_waits_total[2m])",
          "legendFormat": "Lock Waits/s"
        },
        {
          "expr": "rate(mssql_deadlocks_total[2m])",
          "legendFormat": "Deadlocks/s"
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "Database Sizes",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 }
    },
    {
      "id": 31,
      "type": "bargauge",
      "title": "Database Size",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      },
      "targets": [
        {
          "expr": "mssql_db_size_bytes",
          "legendFormat": "{{db}}",
          "instant": true
        }
      ]
    },
    {
      "id": 32,
      "type": "bargauge",
      "title": "Log File Size",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      },
      "targets": [
        {
          "expr": "mssql_log_size_bytes",
          "legendFormat": "{{db}}",
          "instant": true
        }
      ]
    }
  ]
}
