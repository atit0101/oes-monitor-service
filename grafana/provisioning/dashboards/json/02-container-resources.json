{
  "uid": "oes-containers",
  "title": "OES Container Resources",
  "tags": ["oes", "infrastructure"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "container",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(container_cpu_usage_seconds_total{name!=\"\"}, name)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2,
        "label": "Container"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "CPU",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "CPU Usage per Container (%)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\"$container\", name!=\"\"}[2m]) * 100",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Memory",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Memory Usage per Container",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\"$container\", name!=\"\"}",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "bargauge",
      "title": "Memory Usage Now",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 536870912 },
              { "color": "red", "value": 1073741824 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\"$container\", name!=\"\"}",
          "legendFormat": "{{name}}",
          "instant": true
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Network",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Network Receive",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      },
      "targets": [
        {
          "expr": "rate(container_network_receive_bytes_total{name=~\"$container\", name!=\"\"}[2m])",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Network Transmit",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      },
      "targets": [
        {
          "expr": "rate(container_network_transmit_bytes_total{name=~\"$container\", name!=\"\"}[2m])",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "Filesystem",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 }
    },
    {
      "id": 31,
      "type": "bargauge",
      "title": "Filesystem Usage",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "container_fs_usage_bytes{name=~\"$container\", name!=\"\"} / container_fs_limit_bytes{name=~\"$container\", name!=\"\"}",
          "legendFormat": "{{name}}",
          "instant": true
        }
      ]
    }
  ]
}
